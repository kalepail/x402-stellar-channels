{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "x402-stellar-channels-demo",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./public"
  },
  "observability": {
    "enabled": true
  }
}
